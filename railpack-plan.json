{
    "phases": {
        "setup": {
            "nixPkgs": ["nodejs_20", "php84", "composer"]
        },
        "install": {
            "cmds": [
                "composer install --no-interaction --no-dev --optimize-autoloader",
                "npm ci"
            ]
        },
        "build": {
            "cmds": [
                "npm run build",
                "php artisan config:cache",
                "php artisan route:cache",
                "php artisan view:cache"
            ]
        }
    },
    "start": {
        "cmd": "php artisan config:clear && php artisan migrate --force && /start-container.sh"
    }
}
